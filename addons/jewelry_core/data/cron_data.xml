<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="gold_price_api_config_default" model="gold.price.api.config">
        <field name="name">Default Gold API Config</field>
        <field name="api_url_usd">https://api.gold-api.com/price/XAU</field>
        <field name="api_url_dzd">https://www.exchangedz.com/rates/usd-to-dzd</field>
        <field name="usd_price_json_path">price</field>
        <field name="auto_fetch" eval="True"/>
        <field name="interval_hours">6</field>
    </record>

    <record id="ir_cron_gold_price_fetch" model="ir.cron">
        <field name="name">Gold Price Auto Fetch</field>
        <field name="model_id" ref="model_ir_cron"/>
        <field name="state">code</field>
        <field name="code">model._gold_price_auto_fetch()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
