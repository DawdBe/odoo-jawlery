<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_product_barcode_label" model="ir.actions.report">
        <field name="name">Product Barcode Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">jewelry_core.product_barcode_label</field>
    </record>

    <template id="product_barcode_label">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="o" t-value="doc"/>
                    <div class="page" style="text-align:center;padding:20mm;">
                        <h2 t-esc="o.display_name"/>
                        <p>
                            <strong>Barcode:</strong>
                            <span t-esc="o.barcode"/>
                        </p>
                        <p>
                            <img t-att-src="'/report/barcode/Code128/%s' % o.barcode"
                                 style="width:100%;max-width:300px;height:120px;"/>
                        </p>
                        <p>
                            <span t-esc="o.barcode" style="font-family:monospace;font-size:18px;"/>
                        </p>
                        <p t-if="o.metal_type_id">
                            Metal Type: <span t-esc="o.metal_type_id.name"/>
                        </p>
                        <p t-if="o.net_weight">
                            Net Weight: <span t-esc="o.net_weight"/> g
                        </p>
                    </div>
                </t>
            </t>
            <script>
                window.addEventListener('load', function() {
                    setTimeout(function() { window.print(); }, 500);
                });
            </script>
        </t>
    </template>

    <record id="action_print_product_barcode" model="ir.actions.server">
        <field name="name">Imprimer l'étiquette</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
        <field name="state">code</field>
        <field name="code">action = env['product.template'].browse(record.id).action_print_barcode()</field>
    </record>
</odoo>
