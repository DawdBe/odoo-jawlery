<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="jewelry_core.GoldChartWidget">
        <div class="o_gold_chart_container" style="margin-top: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <strong style="font-size: 15px;">Gold Price History</strong>
                <div style="display: flex; gap: 6px;">
                    <t t-foreach="['today','7d','30d','90d','1y','all']" t-as="r" t-key="r">
                        <button
                            t-attf-class="btn btn-sm #{state.range == r ? 'btn-secondary' : 'btn-light'}"
                            t-on-click="() => this.onFilter(r)"
                            t-esc="r === 'all' ? 'All' : r"
                            style="min-width: 40px;"
                        />
                    </t>
                </div>
            </div>

            <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
                <div style="font-size: 14px; font-weight: 600; color: #1a1a2e; margin-bottom: 8px;">Bourse 24K History</div>
                <div style="height: 260px; width: 100%; position: relative;">
                    <canvas t-ref="canvasBourse"/>
                </div>
            </div>

            <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 16px;">
                <div style="font-size: 14px; font-weight: 600; color: #c9a84c; margin-bottom: 8px;">International Market History</div>
                <div style="height: 260px; width: 100%; position: relative;">
                    <canvas t-ref="canvasMarket"/>
                </div>
            </div>

            <div t-if="state.loading"
                 style="text-align: center; margin-top: 8px; font-size: 13px; color: #888;">
                Loading…
            </div>
        </div>
    </t>

</templates>
