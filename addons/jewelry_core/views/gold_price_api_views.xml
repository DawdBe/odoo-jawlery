<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_price_api_config_tree" model="ir.ui.view">
        <field name="name">gold.price.api.config.tree</field>
        <field name="model">gold.price.api.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="api_url_usd"/>
                <field name="auto_fetch"/>
                <field name="last_fetch_time"/>
                <field name="last_fetch_status"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_price_api_config_form" model="ir.ui.view">
        <field name="name">gold.price.api.config.form</field>
        <field name="model">gold.price.api.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_fetch_now" string="Fetch Now" type="object"
                                class="btn-primary" icon="fa-refresh"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="auto_fetch"/>
                            <field name="interval_hours"/>
                            <field name="parallel_premium_percent" help="Fallback: premium over official rate if ChangeDA scraping fails"/>
                        </group>
                        <group>
                            <field name="last_fetch_time"/>
                            <field name="last_fetch_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="api_config" string="API Configuration">
                            <group>
                                <group string="Gold Price API">
                                    <field name="api_url_usd"/>
                                    <field name="usd_price_json_path"/>
                                </group>
                                <group string="DZD Parallel Rate (ChangeDA scraper)">
                                    <field name="api_url_dzd"/>
                                    <field name="dzd_rate_scrape_pattern"/>
                                </group>
                            </group>
                        </page>
                        <page name="logs" string="Fetch Logs">
                            <field name="log_ids">
                                <tree>
                                    <field name="fetch_date"/>
                                    <field name="status"/>
                                    <field name="usd_price" widget="monetary"/>
                                    <field name="dzd_rate"/>
                                    <field name="market_rate" widget="monetary"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gold_price_api_config" model="ir.actions.act_window">
        <field name="name">Gold API Config</field>
        <field name="res_model">gold.price.api.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_gold_price_api_config" name="Gold API Config"
              parent="menu_jewelry_config" action="action_gold_price_api_config" sequence="25"/>
</odoo>
