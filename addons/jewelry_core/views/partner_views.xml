<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_jewelry_partner" model="ir.actions.act_window">
        <field name="name">Partners</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{'default_partner_type': 'client'}</field>
    </record>

    <record id="action_jewelry_supplier" model="ir.actions.act_window">
        <field name="name">Suppliers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('partner_type', '=', 'frs')]</field>
        <field name="context">{'default_partner_type': 'frs'}</field>
    </record>

    <record id="view_res_partner_jewelry_form" model="ir.ui.view">
        <field name="name">res.partner.jewelry.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="function" position="replace"/>
            <field name="website" position="replace"/>
            <field name="title" position="replace"/>
            <field name="lang" position="replace"/>
            <field name="active_lang_count" position="replace"/>
            <xpath expr="//field[@name='vat']" position="replace">
                <field name="partner_type" widget="radio"/>
                <field name="user_id" invisible="1"/>
                <field name="duplicated_bank_account_partners_count" invisible="1"/>
            </xpath>
            <xpath expr="//span[@name='address_name']" position="replace">
                <span class="o_form_label o_td_label" name="address_name">
                    <field name="type" invisible="1"/>
                    <b>Address</b>
                </span>
            </xpath>
            <xpath expr="//page[@name='contact_addresses']" position="replace"/>
            <xpath expr="//page[@name='accounting']" position="replace"/>
            <xpath expr="//page[@name='accounting_disabled']" position="replace"/>
        </field>
    </record>

    <record id="view_res_partner_jewelry_tree" model="ir.ui.view">
        <field name="name">res.partner.jewelry.tree</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="display_name" position="after">
                <field name="partner_type"/>
                <field name="phone"/>
            </field>
            <field name="email" position="replace"/>
            <field name="phone" position="replace"/>
        </field>
    </record>

    <record id="view_res_partner_jewelry_remove_chatter" model="ir.ui.view">
        <field name="name">res.partner.jewelry.remove.chatter</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div class="oe_chatter" position="replace"/>
        </field>
    </record>
</odoo>
