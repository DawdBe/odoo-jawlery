<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_jewelry_form" model="ir.ui.view">
        <field name="name">product.template.jewelry.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook//page[1]" position="after">
                <page name="jewelry" string="Jewelry">
                    <group>
                        <group>
                            <field name="metal_type_id"/>
                            <field name="jewelry_category"/>
                            <field name="style"/>
                        </group>
                        <group>
                            <field name="gross_weight"/>
                            <field name="stone_weight"/>
                            <field name="net_weight"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_jewelry_tree" model="ir.ui.view">
        <field name="name">product.template.jewelry.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="list_price" position="after">
                <field name="metal_type_id"/>
                <field name="net_weight"/>
            </field>
        </field>
    </record>

    <record id="view_product_product_jewelry_form" model="ir.ui.view">
        <field name="name">product.product.jewelry.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="jewelry" string="Jewelry">
                    <group>
                        <field name="serial_number"/>
                        <field name="certificate_number"/>
                        <field name="weight"/>
                        <field name="location_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_category_jewelry_form" model="ir.ui.view">
        <field name="name">product.category.jewelry.form</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="has_weight"/>
                <field name="is_jewelry"/>
            </xpath>
            <group name="logistics" position="replace"/>
        </field>
    </record>

    <record id="view_product_category_jewelry_hide_valuation" model="ir.ui.view">
        <field name="name">product.category.jewelry.hide.valuation</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="stock_account.view_category_property_form_stock"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field/@name='property_cost_method']" position="replace"/>
        </field>
    </record>
</odoo>

