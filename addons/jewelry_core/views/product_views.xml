<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_jewelry_form" model="ir.ui.view">
        <field name="name">product.template.jewelry.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Print Barcode stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_print_barcode"
                        string="Print Barcode"
                        type="object"
                        icon="fa-barcode"
                        class="oe_stat_button"/>
            </xpath>

            <!-- Add clean field group before the notebook -->
            <xpath expr="//notebook" position="before">
                <group>
                    <group name="jewelry_left">
                        <field name="barcode" readonly="1"/>
                        <field name="categ_id" options="{'no_create': True}"/>
                        <field name="metal_type_id" options="{'no_create': True}"/>
                        <field name="jewelry_category"/>
                        <field name="style"/>
                    </group>
                    <group name="jewelry_right">
                        <field name="net_weight"/>
                        <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}"/>
                        <field name="standard_price" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}"/>
                        <field name="active"/>
                    </group>
                </group>
            </xpath>

            <!-- Hide the notebook (keeps other views' xpath targets intact) -->
            <xpath expr="//notebook" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide sale/purchase toggles -->
            <xpath expr="//div[@name='options']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Print Labels header button -->
            <xpath expr="//header/button[@name='action_open_label_layout']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_tree_hide_print_labels" model="ir.ui.view">
        <field name="name">product.template.tree.hide.print.labels</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_label_layout']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_tree_hide_print_labels" model="ir.ui.view">
        <field name="name">product.product.tree.hide.print.labels</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_label_layout']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_jewelry_hide_default_code" model="ir.ui.view">
        <field name="name">product.template.jewelry.hide.default.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="replace"/>
            <xpath expr="//field[@name='barcode'][last()]" position="replace"/>
        </field>
    </record>

    <record id="view_product_template_jewelry_tree" model="ir.ui.view">
        <field name="name">product.template.jewelry.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="list_price" position="after">
                <field name="metal_type_id"/>
                <field name="net_weight"/>
            </field>
        </field>
    </record>

    <record id="view_product_category_jewelry_form" model="ir.ui.view">
        <field name="name">product.category.jewelry.form</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="has_weight"/>
                <field name="is_jewelry"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_jewelry_remove_chatter" model="ir.ui.view">
        <field name="name">product.template.jewelry.remove.chatter</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <div class="oe_chatter" position="replace"/>
        </field>
    </record>

    <record id="view_stock_picking_jewelry_remove_chatter" model="ir.ui.view">
        <field name="name">stock.picking.jewelry.remove.chatter</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <div class="oe_chatter" position="replace"/>
        </field>
    </record>
</odoo>
