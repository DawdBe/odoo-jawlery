<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_price_overview_form" model="ir.ui.view">
        <field name="name">gold.price.overview.form</field>
        <field name="model">gold.price.overview</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_refresh" string="⟳ Refresh from API"
                            type="object" class="btn-primary"/>
                    <button name="action_save_rates" string="💾 Save Rates"
                            type="object" class="btn-success"/>
                </header>
                <sheet>

                    <!-- ══════════ GOLD KPI ══════════ -->
                    <div class="bg-light" style="padding: 20px; margin-bottom: 8px; border-radius: 8px;">
                        <h3 style="margin: 0 0 12px 0; font-size: 18px; font-weight: 600; color: #1a1a2e;">Gold</h3>
                        <div id="price_box" style="display: flex; align-items: center; font-size: 16px;">
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>24k USD/g</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #1a1a2e;">
                                        <field name="base_24k_usd_g" widget="float" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #1a1a2e; margin-left: 6px;">USD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Bursa 24k</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #1a1a2e;">
                                        <field name="bursa_24k_dzd" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #1a1a2e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Market 24k</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #1a1a2e;">
                                        <field name="market_24k_dzd" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #1a1a2e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>DZD Parallel</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #1a1a2e;">
                                        <field name="dzd_parallel_rate" readonly="1" widget="float" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #1a1a2e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ══════════ SILVER KPI (below Gold KPI) ══════════ -->
                    <div class="bg-light" style="padding: 20px; margin: 0 0 8px 0; border-radius: 8px;">
                        <h3 style="margin: 0 0 12px 0; font-size: 18px; font-weight: 600; color: #4a4a6e;">Silver</h3>
                        <div id="silver_price_box" style="display: flex; align-items: center; font-size: 16px;">
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Silver USD/g</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #4a4a6e;">
                                        <field name="base_silver_usd_g" widget="float" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #4a4a6e; margin-left: 6px;">USD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Bursa 1000</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #4a4a6e;">
                                        <field name="silver_bursa_1000_dzd" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #4a4a6e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Market 1000</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #4a4a6e;">
                                        <field name="silver_market_1000_dzd" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #4a4a6e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>DZD Parallel</strong>
                                <div style="display: flex; justify-content: center; align-items: baseline;">
                                    <span style="font-size: 32px; font-weight: bold; color: #4a4a6e;">
                                        <field name="dzd_parallel_rate" readonly="1" widget="float" class="text-center"/>
                                    </span>
                                    <span style="font-size: 16px; font-weight: bold; color: #4a4a6e; margin-left: 6px;">DZD</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ══════════ TABLES: Gold left / Silver right ══════════ -->
                    <div style="display: flex; gap: 16px;">
                        <div style="flex: 1; min-width: 0;">
                            <group string="Gold Prices (per gram)">
                                <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                                    <thead>
                                        <tr>
                                            <th style="padding: 8px; text-align: center; width: 60px;">Karat</th>
                                            <th style="padding: 8px; text-align: center; width: 60px;">Purity</th>
                                            <th style="padding: 8px; text-align: center;">Bursa</th>
                                            <th style="padding: 8px; text-align: center;">Market</th>
                                            <th style="padding: 8px; text-align: center;">Spread</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td style="padding: 8px; text-align: center;"><strong>24k</strong></td>
                                            <td style="padding: 8px; text-align: center;">99.99%</td>
                                            <td style="padding: 8px;"><field name="bursa_24k_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_24k_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_24k" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 8px; text-align: center;"><strong>21k</strong></td>
                                            <td style="padding: 8px; text-align: center;">87.50%</td>
                                            <td style="padding: 8px;"><field name="bursa_21k_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_21k_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_21k" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr style="background-color: #f8f9fa;">
                                            <td style="padding: 8px; text-align: center;"><strong>18k</strong></td>
                                            <td style="padding: 8px; text-align: center;">75.00%</td>
                                            <td style="padding: 8px;"><field name="bursa_18k_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_18k_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_18k" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 8px; text-align: center; padding-left: 16px;">18k</td>
                                            <td style="padding: 8px; text-align: center;">72.00%</td>
                                            <td style="padding: 8px;"><field name="bursa_18k_720_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_18k_720_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_18k_720" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 8px; text-align: center; padding-left: 16px;">18k</td>
                                            <td style="padding: 8px; text-align: center;">71.00%</td>
                                            <td style="padding: 8px;"><field name="bursa_18k_710_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_18k_710_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_18k_710" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 8px; text-align: center; padding-left: 16px;">18k</td>
                                            <td style="padding: 8px; text-align: center;">70.50%</td>
                                            <td style="padding: 8px;"><field name="bursa_18k_705_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="market_18k_705_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="spread_18k_705" widget="monetary" class="text-center"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </group>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <group string="Silver Prices (per gram)">
                                <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                                    <thead>
                                        <tr>
                                            <th style="padding: 8px; text-align: center; width: 60px;">Purity</th>
                                            <th style="padding: 8px; text-align: center;">Bursa</th>
                                            <th style="padding: 8px; text-align: center;">Market</th>
                                            <th style="padding: 8px; text-align: center;">Spread</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td style="padding: 8px; text-align: center;"><strong>1000</strong></td>
                                            <td style="padding: 8px;"><field name="silver_bursa_1000_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="silver_market_1000_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="silver_spread_1000" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr style="background-color: #f8f9fa;">
                                            <td style="padding: 8px; text-align: center;"><strong>925</strong></td>
                                            <td style="padding: 8px;"><field name="silver_bursa_925_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="silver_market_925_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="silver_spread_925" widget="monetary" class="text-center"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 8px; text-align: center;"><strong>500</strong></td>
                                            <td style="padding: 8px;"><field name="silver_bursa_500_dzd" widget="monetary" class="text-center"/></td>
                                            <td style="padding: 8px;"><field name="silver_market_500_dzd" widget="monetary" class="text-center text-bold"/></td>
                                            <td style="padding: 8px;"><field name="silver_spread_500" widget="monetary" class="text-center"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </group>
                        </div>
                    </div>

                    <field name="chart_data_text" widget="unified_chart" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gold_price_overview" model="ir.actions.act_window">
        <field name="name">Gold Price Overview</field>
        <field name="res_model">gold.price.overview</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>
</odoo>
