<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_price_overview_form" model="ir.ui.view">
        <field name="name">gold.price.overview.form</field>
        <field name="model">gold.price.overview</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_refresh" string="⟳ Refresh from API"
                            type="object" class="btn-primary"/>
                    <button name="action_save_rates" string="💾 Save Rates"
                            type="object" class="btn-success"/>
                </header>
                <sheet>

                    <div id="price_box" class="bg-light" style="padding: 20px; margin-bottom: 16px; border-radius: 8px;">
                        <div style="display: flex; align-items: center; font-size: 16px;">
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Bursa 24k</strong>
                                <div style="font-size: 32px; font-weight: bold; color: #1a1a2e; display: flex; align-items: center; justify-content: center; white-space: nowrap;">
                                    <field name="bursa_24k_dzd" class="text-center"/>
                                    <span style="margin-left: 1px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>Market 24k</strong>
                                <div style="font-size: 32px; font-weight: bold; color: #1a1a2e; display: flex; align-items: center; justify-content: center; white-space: nowrap;">
                                    <field name="market_24k_dzd" class="text-center"/>
                                    <span style="margin-left: 1px;">DZD</span>
                                </div>
                            </div>
                            <div style="width: 1px; height: 60px; background: #dee2e6; margin: 0 24px;"></div>
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <strong>DZD Parallel</strong>
                                <div style="font-size: 32px; font-weight: bold; color: #1a1a2e; display: flex; align-items: center; justify-content: center; white-space: nowrap;">
                                    <field name="dzd_parallel_rate" readonly="1" widget="float" class="text-center"/>
                                    <span style="margin-left: 1px;">DZD</span>
                                </div>
                            </div>
                        </div>
                        <div style="text-align: center; font-size: 13px; color: #888; margin-top: 8px;">
                            <field name="last_update" readonly="1"/>
                        </div>
                    </div>

                    <group string="Gold Prices (per gram)">
                        <table class="table table-bordered" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th style="padding: 8px; text-align: center; width: 100px;">Karat</th>
                                    <th style="padding: 8px; text-align: center; width: 100px;">Purity</th>
                                    <th style="padding: 8px; text-align: center;">Bursa (DZD/g)</th>
                                    <th style="padding: 8px; text-align: center;">Market (DZD/g)</th>
                                    <th style="padding: 8px; text-align: center;">Spread (DZD/g)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 8px; text-align: center;"><strong>24k</strong></td>
                                    <td style="padding: 8px; text-align: center;">99.99%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_24k_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_24k_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_24k" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; text-align: center;"><strong>21k</strong></td>
                                    <td style="padding: 8px; text-align: center;">87.50%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_21k_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_21k_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_21k" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                                <tr style="background-color: #f8f9fa;">
                                    <td style="padding: 8px; text-align: center;"><strong>18k</strong></td>
                                    <td style="padding: 8px; text-align: center;">75.00%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_18k_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_18k_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_18k" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; text-align: center; padding-left: 24px;">18k</td>
                                    <td style="padding: 8px; text-align: center;">72.00%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_18k_720_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_18k_720_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_18k_720" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; text-align: center; padding-left: 24px;">18k</td>
                                    <td style="padding: 8px; text-align: center;">71.00%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_18k_710_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_18k_710_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_18k_710" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px; text-align: center; padding-left: 24px;">18k</td>
                                    <td style="padding: 8px; text-align: center;">70.50%</td>
                                    <td style="padding: 8px;">
                                        <field name="bursa_18k_705_dzd" widget="monetary" class="text-center"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="market_18k_705_dzd" widget="monetary" class="text-center text-bold"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <field name="spread_18k_705" widget="monetary" class="text-center"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gold_price_overview" model="ir.actions.act_window">
        <field name="name">Gold Price Overview</field>
        <field name="res_model">gold.price.overview</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>
</odoo>
