<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_supplier_account_tree" model="ir.ui.view">
        <field name="name">supplier.account.tree</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="partner_type"/>
                <field name="cash_solde" widget="monetary" string="Solde Espèces"/>
                <field name="last_transaction_date"/>
            </tree>
        </field>
    </record>

    <record id="view_supplier_gold_balance_tree" model="ir.ui.view">
        <field name="name">supplier.gold.balance.tree</field>
        <field name="model">supplier.gold.balance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="supplier_account_id"/>
                <field name="working_purity" string="Pureté travail (‰)"/>
                <field name="gold_creance" string="Créance (g)"/>
                <field name="gold_dette" string="Dette (g)"/>
                <field name="gold_solde" string="Solde Or (g)"/>
            </tree>
        </field>
    </record>

    <record id="view_supplier_gold_balance_search" model="ir.ui.view">
        <field name="name">supplier.gold.balance.search</field>
        <field name="model">supplier.gold.balance</field>
        <field name="arch" type="xml">
            <search>
                <field name="supplier_account_id"/>
                <field name="working_purity"/>
            </search>
        </field>
    </record>

    <record id="action_supplier_gold_balance" model="ir.actions.act_window">
        <field name="name">Gold Balances</field>
        <field name="res_model">supplier.gold.balance</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_supplier_account_id': active_id}</field>
    </record>

    <record id="view_supplier_account_form" model="ir.ui.view">
        <field name="name">supplier.account.form</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_settlement" type="object"
                                string="Règlement" class="oe_stat_button"
                                icon="fa-credit-card"/>
                    </div>
                    <field name="cash_settlement_count" invisible="1"/>
                    <field name="gold_settlement_count" invisible="1"/>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="partner_type"/>
                        </group>
                        <group string="Espèces">
                            <field name="cash_creance" string="Créance" widget="monetary"/>
                            <field name="cash_dette" string="Dette" widget="monetary"/>
                            <field name="cash_solde" string="Solde" widget="monetary" class="o_stat_info"/>
                        </group>
                    </group>
                    <group string="Or">
                        <field name="working_purity" string="Pureté de travail (‰)"
                               help="Tous les soldes or de ce fournisseur sont convertis vers cette pureté. Modifiez cette valeur pour recalculer instantanément tous les soldes sans modifier les écritures historiques."/>
                        <field name="gold_creance" string="Créance (g)" readonly="1"/>
                        <field name="gold_dette" string="Dette (g)" readonly="1"/>
                        <field name="gold_solde" string="Solde (g)" readonly="1" class="o_stat_info"/>
                    </group>
                    <notebook>
                        <page name="tickets" string="Ventes &amp; Achats">
                            <div class="oe_button_box" name="ticket_button_box">
                                <button name="%(jewelry_transactions.action_jewelry_ticket)d" type="action"
                                        string="Tous les tickets"
                                        class="btn-primary"
                                        context="{'default_partner_id': partner_id, 'search_default_partner_id': partner_id}"/>
                            </div>
                            <field name="ticket_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="payment_status"/>
                                    <field name="product_status"/>
                                    <field name="total_cash_in" widget="monetary"/>
                                    <field name="total_cash_out" widget="monetary"/>
                                    <field name="balance" widget="monetary"/>
                                    <button name="action_open_ticket_form" type="object"
                                            string="Open" icon="fa-external-link"/>
                                </tree>
                            </field>
                        </page>
                        <page name="gold_movements" string="Gold Movements">
                            <field name="gold_movement_ids" context="{'active_test': False}" create="0" delete="0">
                                <tree>
                                    <field name="date"/>
                                    <field name="purpose"/>
                                    <field name="type"/>
                                    <field name="weight" string="Poids (g)"/>
                                    <field name="purity" string="Pureté (‰)"/>
                                    <field name="metal_type_id" optional="show"/>
                                    <field name="description"/>
                                    <field name="inactive_reason" optional="show"/>
                                    <field name="active" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page name="settlements" string="Règlements">
                            <group string="Règlements Espèces">
                                <button name="action_open_cash_settlements" type="object"
                                        string="Voir tout l'historique" class="btn-secondary"/>
                                <field name="cash_settlement_ids" nolabel="1" create="0" delete="0">
                                    <tree limit="10">
                                        <field name="date"/>
                                        <field name="amount" widget="monetary"/>
                                        <field name="type"/>
                                        <field name="payment_method"/>
                                        <field name="description"/>
                                    </tree>
                                </field>
                            </group>
                            <group string="Règlements Or">
                                <button name="action_open_gold_settlements" type="object"
                                        string="Voir tout l'historique" class="btn-secondary"/>
                                <field name="gold_movement_ids" nolabel="1"
                                       domain="[('purpose', '=', 'settlement')]"
                                       context="{'active_test': False}" create="0" delete="0">
                                    <tree limit="10">
                                        <field name="date"/>
                                        <field name="weight" string="Poids (g)"/>
                                        <field name="purity" string="Pureté (‰)"/>
                                        <field name="metal_type_id"/>
                                        <field name="description"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_movement_form" model="ir.ui.view">
        <field name="name">gold.movement.form</field>
        <field name="model">gold.movement</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="supplier_account_id"/>
                            <field name="partner_id"/>
                            <field name="purpose"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="weight" string="Poids (g)"/>
                            <field name="purity" string="Pureté (‰)"/>
                            <field name="metal_type_id"/>
                            <field name="date"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <group string="Audit">
                        <group>
                            <field name="active"/>
                            <field name="inactive_reason"/>
                        </group>
                        <group>
                            <field name="ticket_id"/>
                            <field name="origin_model"/>
                            <field name="origin_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_supplier_account" model="ir.actions.act_window">
        <field name="name">Supplier Accounts</field>
        <field name="res_model">supplier.account</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
