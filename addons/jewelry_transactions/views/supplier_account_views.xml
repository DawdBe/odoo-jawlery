<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_supplier_account_tree" model="ir.ui.view">
        <field name="name">supplier.account.tree</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="partner_type"/>
                <field name="weight_balance"/>
                <field name="cash_balance" widget="monetary"/>
                <field name="last_rate_used" widget="monetary"/>
                <field name="last_transaction_date"/>
            </tree>
        </field>
    </record>

    <record id="view_supplier_account_form" model="ir.ui.view">
        <field name="name">supplier.account.form</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="partner_type"/>
                        </group>
                        <group>
                            <field name="weight_balance"/>
                            <field name="cash_balance" widget="monetary"/>
                            <field name="last_rate_used" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="purchases" string="Purchase Orders">
                            <field name="purchase_order_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="gold_weight_in"/>
                                    <field name="gold_weight_out"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_supplier_account" model="ir.actions.act_window">
        <field name="name">Supplier Accounts</field>
        <field name="res_model">supplier.account</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
