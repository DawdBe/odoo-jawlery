<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_supplier_account_tree" model="ir.ui.view">
        <field name="name">supplier.account.tree</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="partner_type"/>
                <field name="weight_balance"/>
                <field name="balance" widget="monetary"/>
                <field name="last_transaction_date"/>
            </tree>
        </field>
    </record>

    <record id="view_supplier_account_form" model="ir.ui.view">
        <field name="name">supplier.account.form</field>
        <field name="model">supplier.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="partner_type"/>
                        </group>
                        <group>
                            <field name="weight_balance"/>
                            <field name="balance" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="tickets" string="Ventes &amp; Achats">
                            <div class="oe_button_box" name="ticket_button_box">
                                <button name="%(jewelry_transactions.action_jewelry_ticket)d" type="action"
                                        string="Tous les tickets"
                                        class="btn-primary"
                                        context="{'default_partner_id': partner_id, 'search_default_partner_id': partner_id}"/>
                            </div>
                            <field name="ticket_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="payment_status"/>
                                    <field name="product_status"/>
                                    <field name="total_cash_in" widget="monetary"/>
                                    <field name="total_cash_out" widget="monetary"/>
                                    <field name="balance" widget="monetary"/>
                                    <button name="action_open_ticket_form" type="object"
                                            string="Open" icon="fa-external-link"/>
                                </tree>
                            </field>
                        </page>
                        <page name="gold_movements" string="Gold Movements">
                            <field name="gold_movement_ids">
                                <tree editable="bottom">
                                    <field name="purpose"/>
                                    <field name="type"/>
                                    <field name="weight"/>
                                    <field name="metal_type_id"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="reversed" invisible="1"/>
                                    <button name="action_reverse" type="object"
                                            string="Reverse" icon="fa-undo"
                                            confirm="Are you sure you want to reverse this movement?"
                                            invisible="reversed"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_supplier_account" model="ir.actions.act_window">
        <field name="name">Supplier Accounts</field>
        <field name="res_model">supplier.account</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
