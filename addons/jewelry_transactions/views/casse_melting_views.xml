<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_casse_melting_tree" model="ir.ui.view">
        <field name="name">casse.melting.tree</field>
        <field name="model">casse.melting</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="metal_type_result"/>
                <field name="weight_before" string="Poids mesuré avant (g)"/>
                <field name="weight_after" string="Poids après (g)"/>
                <field name="wastage_weight" string="Perte (g)"/>
                <field name="profit" widget="monetary"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_casse_melting_form" model="ir.ui.view">
        <field name="name">casse.melting.form</field>
        <field name="model">casse.melting</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm Melting" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="metal_type_result"/>
                            <field name="working_purity" string="Pureté de travail (‰)"/>
                        </group>
                    </group>
                    <group string="Or mesuré">
                        <group>
                            <field name="weight_before" string="Poids total mesuré avant (g)" readonly="1"/>
                        </group>
                        <group>
                            <field name="weight_after" string="Poids après fusion (g)"
                                   readonly="state == 'done'"/>
                        </group>
                    </group>
                    <group string="Or de travail (calculs ERP)">
                        <group>
                            <field name="weight_before_working" string="Poids travail avant (g)" readonly="1"/>
                        </group>
                        <group>
                            <field name="wastage_weight" string="Perte (g)" readonly="1"/>
                            <field name="total_cost" widget="monetary" readonly="1"/>
                            <field name="refined_value" widget="monetary" readonly="1"/>
                            <field name="profit" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <group string="Lignes de fusion">
                        <field name="line_ids" readonly="state == 'done'" nolabel="1">
                            <tree>
                                <field name="ticket_id" readonly="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="weight" string="Poids mesuré (g)" readonly="1"/>
                                <field name="measured_purity" string="Pureté mesurée (‰)" readonly="1"/>
                                <field name="working_purity" string="Pureté travail (‰)" readonly="1"/>
                                <field name="working_weight" string="Poids travail (g)" readonly="1"/>
                                <field name="cost" string="Coût" widget="monetary" readonly="1"/>
                                <button name="action_open_ticket" type="object"
                                        string=" " icon="fa-external-link" class="btn-link"/>
                            </tree>
                        </field>
                    </group>
                    <group>
                        <field name="notes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_casse_melting" model="ir.actions.act_window">
        <field name="name">Casse Melting</field>
        <field name="res_model">casse.melting</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
