<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_casse_melting_tree" model="ir.ui.view">
        <field name="name">casse.melting.tree</field>
        <field name="model">casse.melting</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="metal_type_result"/>
                <field name="weight_before"/>
                <field name="weight_after"/>
                <field name="wastage_weight"/>
                <field name="profit" widget="monetary"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_casse_melting_form" model="ir.ui.view">
        <field name="name">casse.melting.form</field>
        <field name="model">casse.melting</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm Melting" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="metal_type_result"/>
                        </group>
                    </group>
                    <group string="Weights &amp; Costs">
                        <group>
                            <field name="weight_before" readonly="1"/>
                            <field name="weight_after"
                                   readonly="state == 'done'"/>
                            <field name="wastage_weight" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_cost" widget="monetary" readonly="1"/>
                            <field name="refined_value" widget="monetary" readonly="1"/>
                            <field name="profit" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" readonly="state == 'done'">
                        <tree>
                            <field name="ticket_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="weight" string="Weight (g)" readonly="1"/>
                            <field name="cost" string="Cost" widget="monetary" readonly="1"/>
                            <button name="action_open_ticket" type="object"
                                    string=" " icon="fa-external-link" class="btn-link"/>
                        </tree>
                    </field>
                    <group>
                        <field name="notes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_casse_melting" model="ir.actions.act_window">
        <field name="name">Casse Melting</field>
        <field name="res_model">casse.melting</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
