<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_jewelry_form" model="ir.ui.view">
        <field name="name">purchase.order.jewelry.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_type"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="jewelry" string="Gold">
                    <group>
                        <field name="is_consignment"/>
                        <field name="gold_weight_in"/>
                        <field name="gold_weight_out"/>
                        <field name="gold_metal_type"/>
                    </group>
                </page>
            </xpath>
            <!-- Remove fiscal position -->
            <field name="fiscal_position_id" position="replace"/>
            <!-- Remove payment terms -->
            <field name="payment_term_id" position="replace"/>
            <!-- Remove buyer -->
            <field name="user_id" position="replace"/>

            <!-- Remove multi-currency -->
            <field name="currency_id" position="replace"/>
        </field>
    </record>

    <record id="view_purchase_order_line_jewelry_form" model="ir.ui.view">
        <field name="name">purchase.order.line.jewelry.form</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_form2"/>
        <field name="arch" type="xml">
            <field name="price_unit" position="after">
                <field name="unit_price_per_gram" widget="monetary"/>
                <field name="weight"/>
                <field name="metal_type_id"/>
                <field name="is_raw_gold"/>
                <field name="line_type"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_line_jewelry_tree" model="ir.ui.view">
        <field name="name">purchase.order.line.jewelry.tree</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <field name="price_unit" position="after">
                <field name="weight"/>
                <field name="metal_type_id"/>
                <field name="line_type"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_jewelry_remove_chatter" model="ir.ui.view">
        <field name="name">purchase.order.jewelry.remove.chatter</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <div class="oe_chatter" position="replace"/>
        </field>
    </record>
</odoo>
