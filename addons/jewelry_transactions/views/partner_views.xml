<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_jewelry_tickets" model="ir.ui.view">
        <field name="name">res.partner.jewelry.tickets</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']//group[@name='container_row_2']" position="replace">
                <group name="container_row_2">
                    <div class="oe_button_box" name="ticket_button_box">
                        <button name="%(action_jewelry_ticket)d" type="action"
                                string="Tous les tickets"
                                class="btn-primary"
                                context="{'default_partner_id': active_id, 'search_default_partner_id': active_id}"/>
                    </div>
                    <field name="ticket_ids" nolabel="1">
                        <tree>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="payment_status"/>
                            <field name="product_status"/>
                            <field name="total_cash_in" widget="monetary"/>
                            <field name="total_cash_out" widget="monetary"/>
                            <field name="balance" widget="monetary"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
    <record id="view_partner_jewelry_supplier_account_button" model="ir.ui.view">
        <field name="name">res.partner.jewelry.supplier.account.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_supplier_account" type="object"
                        string="Supplier Account"
                        class="oe_stat_button"
                        icon="fa-balance-scale"
                        invisible="partner_type not in ('frs', 'atelier')"/>
                <button name="action_open_associate_account" type="object"
                        string="Associate Account"
                        class="oe_stat_button"
                        icon="fa-users"
                        invisible="partner_type != 'associe'"/>
            </xpath>
        </field>
    </record>
</odoo>
