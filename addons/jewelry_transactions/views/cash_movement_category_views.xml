<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cash_movement_category_tree" model="ir.ui.view">
        <field name="name">cash.movement.category.tree</field>
        <field name="model">cash.movement.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="direction"/>
                <field name="parent_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_cash_movement_category_form" model="ir.ui.view">
        <field name="name">cash.movement.category.form</field>
        <field name="model">cash.movement.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="direction"/>
                            <field name="parent_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_movement_category_search" model="ir.ui.view">
        <field name="name">cash.movement.category.search</field>
        <field name="model">cash.movement.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter name="entree" string="Entrée" domain="[('direction','=','entree')]"/>
                <filter name="sortie" string="Sortie" domain="[('direction','=','sortie')]"/>
                <separator/>
                <filter name="active" string="Actives" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archivées" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_cash_movement_category" model="ir.actions.act_window">
        <field name="name">Cash Movement Categories</field>
        <field name="res_model">cash.movement.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define cash movement categories for income and expense tracking.
            </p>
            <p>
                Categories classify every cash movement (e.g. Rent, Salary, Sales Revenue).
                Selecting a category automatically sets the movement direction.
            </p>
        </field>
    </record>
</odoo>
