<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Barcode scan wizard — popup for scanning/entering product barcodes.
         Shows scanned product details and lets user add to an existing open ticket
         or create a new ticket. Designed for fast POS barcode entry workflow. -->
    <record id="view_product_barcode_scan_wizard" model="ir.ui.view">
        <field name="name">product.barcode.scan.wizard.form</field>
        <field name="model">product.barcode.scan.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="barcode" placeholder="Scan or type barcode here..."/>
                        <field name="product_id" invisible="1"/>
                        <field name="has_open_ticket" invisible="1"/>
                    </group>
                </group>
                <group invisible="not product_id">
                    <group string="Scanned Product">
                        <field name="product_name"/>
                        <field name="product_barcode"/>
                        <field name="product_weight"/>
                        <field name="product_price" widget="monetary"/>
                        <field name="metal_type_id"/>
                    </group>
                </group>
                <group invisible="not product_id">
                    <group string="Ticket">
                        <field name="open_ticket_id" invisible="not has_open_ticket"/>
                        <field name="partner_id" required="not has_open_ticket"/>
                    </group>
                </group>
                <footer>
                    <button name="action_add_to_ticket"
                            string="Add to Open Ticket"
                            type="object"
                            class="btn-primary"
                            invisible="not open_ticket_id"/>
                    <button name="action_create_ticket_and_add"
                            string="Create Ticket &amp; Add"
                            type="object"
                            class="btn-success"
                            invisible="not product_id"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_barcode_scan" model="ir.actions.act_window">
        <field name="name">Scan Barcode</field>
        <field name="res_model">product.barcode.scan.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Supplier Settlement Wizard -->
    <record id="view_supplier_settlement_wizard" model="ir.ui.view">
        <field name="name">supplier.settlement.wizard.form</field>
        <field name="model">supplier.settlement.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="supplier_account_id" invisible="1"/>
                        <field name="partner_id"/>
                    </group>
                </group>
                <group string="Situation actuelle">
                    <group string="Espèces">
                        <field name="current_cash_creance" widget="monetary"/>
                        <field name="current_cash_dette" widget="monetary"/>
                        <field name="current_cash_solde" widget="monetary"/>
                    </group>
                    <group string="Or">
                        <field name="current_gold_creance" string="Créance Or (g)"/>
                        <field name="current_gold_dette" string="Dette Or (g)"/>
                        <field name="current_gold_solde" string="Solde Or (g)"/>
                    </group>
                </group>
                <group string="Règlement">
                    <group string="Espèces">
                        <field name="cash_direction"/>
                        <field name="cash_amount" widget="monetary"/>
                        <field name="payment_method"/>
                    </group>
                    <group string="Or">
                        <field name="gold_direction"/>
                        <field name="gold_weight" string="Poids (g)"/>
                        <field name="gold_purity" string="Pureté (‰)"/>
                        <field name="gold_metal_type_id"/>
                    </group>
                </group>
                <group>
                    <field name="description" placeholder="Motif du règlement..."/>
                </group>
                <group string="Aperçu après règlement">
                    <group>
                        <field name="projected_cash_solde" widget="monetary"/>
                    </group>
                    <group>
                        <field name="projected_gold_solde" string="Solde Or Après (g)"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirmer le règlement"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_supplier_settlement_wizard" model="ir.actions.act_window">
        <field name="name">Règlement Fournisseur</field>
        <field name="res_model">supplier.settlement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
