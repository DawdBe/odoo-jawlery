<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_cash_register_tree" model="ir.ui.view">
        <field name="name">daily.cash.register.tree</field>
        <field name="model">daily.cash.register</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="cashier_id"/>
                <field name="opening_balance" widget="monetary"/>
                <field name="expected_balance" widget="monetary"/>
                <field name="closing_balance" widget="monetary"/>
                <field name="difference" widget="monetary"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_daily_cash_register_form" model="ir.ui.view">
        <field name="name">daily.cash.register.form</field>
        <field name="model">daily.cash.register</field>
        <field name="arch" type="xml">
            <form js_class="daily_cash_register_form">
                <header>
                    <button name="close_register" string="Close Register" type="object"
                            class="btn-primary" invisible="state != 'open'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="cashier_id"/>
                        </group>
                        <group>
                            <field name="opening_balance" widget="monetary"/>
                            <field name="expected_balance" widget="monetary"/>
                            <field name="closing_balance" widget="monetary"/>
                            <field name="difference" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Bill Breakdown">
                        <group>
                            <field name="breakdown_2000"/>
                            <field name="breakdown_1000"/>
                            <field name="breakdown_500"/>
                            <field name="breakdown_200"/>
                        </group>
                        <group>
                            <field name="breakdown_100"/>
                            <field name="breakdown_50"/>
                            <field name="breakdown_20"/>
                            <field name="breakdown_10"/>
                        </group>
                    </group>
                    <separator string="Today's Tickets"/>
                    <field name="ticket_ids" nolabel="1">
                        <tree>
                            <field name="name" string="Ticket #"/>
                            <field name="partner_id" string="Customer"/>
                            <field name="balance" string="Amount" widget="monetary"/>
                            <field name="paid_amount" string="Paid" widget="monetary"/>
                            <field name="remaining_amount" string="Remaining" widget="monetary"/>
                            <field name="payment_status" string="Status"/>
                            <field name="date" string="Date"/>
                        </tree>
                    </field>
                    <separator string="Today's Cash Movements"/>
                    <field name="line_ids" nolabel="1">
                        <tree>
                            <field name="date" string="Time"/>
                            <field name="description" string="Description"/>
                            <field name="ticket_id" string="Ticket" optional="show"/>
                            <field name="partner_id" string="Partner" optional="show"/>
                            <field name="payment_method" string="Method"/>
                            <field name="type" invisible="1"/>
                            <field name="amount" string="In" widget="monetary"
                                   invisible="type != 'entree'"/>
                            <field name="amount" string="Out" widget="monetary"
                                   invisible="type != 'sortie'"/>
                            <field name="reversed" invisible="1"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_daily_cash_register" model="ir.actions.act_window">
        <field name="name">Cash Registers</field>
        <field name="res_model">daily.cash.register</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
