<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_cash_register_tree" model="ir.ui.view">
        <field name="name">daily.cash.register.tree</field>
        <field name="model">daily.cash.register</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="cashier_id"/>
                <field name="opening_balance" widget="monetary"/>
                <field name="expected_balance" widget="monetary"/>
                <field name="closing_balance" widget="monetary"/>
                <field name="difference" widget="monetary"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_daily_cash_register_form" model="ir.ui.view">
        <field name="name">daily.cash.register.form</field>
        <field name="model">daily.cash.register</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="close_register" string="Close Register" type="object"
                            class="btn-primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="cashier_id"/>
                        </group>
                        <group>
                            <field name="opening_balance" widget="monetary"/>
                            <field name="expected_balance" widget="monetary"/>
                            <field name="closing_balance" widget="monetary"/>
                            <field name="difference" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Bill Breakdown">
                        <group>
                            <field name="breakdown_2000"/>
                            <field name="breakdown_1000"/>
                            <field name="breakdown_500"/>
                            <field name="breakdown_200"/>
                        </group>
                        <group>
                            <field name="breakdown_100"/>
                            <field name="breakdown_50"/>
                            <field name="breakdown_20"/>
                            <field name="breakdown_10"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="ticket_id"/>
                            <field name="type"/>
                            <field name="amount" widget="monetary"/>
                            <field name="is_travel_cash"/>
                            <field name="journal_id"/>
                            <field name="partner_id"/>
                            <field name="description"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_daily_cash_register" model="ir.actions.act_window">
        <field name="name">Cash Registers</field>
        <field name="res_model">daily.cash.register</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
