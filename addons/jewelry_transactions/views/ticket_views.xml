<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_jewelry_ticket_tree" model="ir.ui.view">
        <field name="name">jewelry.ticket.tree</field>
        <field name="model">jewelry.ticket</field>
        <field name="arch" type="xml">
            <tree>
                <field name="barcode"/>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="payment_status"/>
                <field name="product_status"/>
                <field name="total_cash_in" widget="monetary"/>
                <field name="total_cash_out" widget="monetary"/>
                <field name="balance" widget="monetary"/>
            </tree>
        </field>
    </record>

    <record id="view_jewelry_ticket_form" model="ir.ui.view">
        <field name="name">jewelry.ticket.form</field>
        <field name="model">jewelry.ticket</field>
        <field name="arch" type="xml">
            <form class="jewelry_ticket_form">
                <header>
                    <field name="payment_status" widget="statusbar"/>
                    <field name="product_status" widget="clickable_statusbar" options="{'clickable': True}"/>
                </header>
                <sheet>
                    <field name="melting_ids" invisible="1"/>
                    <field name="is_supplier_ticket" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_jewelry_ticket_line)d" type="action"
                                string="Lines" class="oe_stat_button"
                                icon="fa-list" context="{'default_ticket_id': active_id}"/>
                        <button name="action_open_melting" type="object"
                                string="Melting" class="oe_stat_button"
                                icon="fa-fire"
                                invisible="not melting_ids"/>
                        <button name="action_open_associate_account" type="object"
                                string="Associate" class="oe_stat_button"
                                icon="fa-users"
                                invisible="partner_id.partner_type != 'associe'"/>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="barcode"/>
                        <field name="partner_id"/>
                        <field name="cashier_id"/>
                        <field name="date"/>
                    </group>
                    <field name="ticket_line_ids">
                        <tree editable="bottom">
                            <field name="line_type"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="weight" string="Poids (g)"/>
                            <field name="purity" string="Pureté (‰)"/>
                            <field name="metal_type_id"/>
                            <field name="price_unit" widget="monetary"
                                   attrs="{'invisible': [('settlement_type', '=', 'gold_credit')]}"/>
                            <field name="price_subtotal" widget="monetary"
                                   attrs="{'invisible': [('settlement_type', '=', 'gold_credit')]}"/>
                            <field name="settlement_type" widget="radio"
                                   attrs="{'invisible': [('parent.is_supplier_ticket', '=', False)]}"/>
                            <field name="remise_amount" widget="monetary"/>
                        </tree>
                    </field>
                    <group string="Totaux">
                        <field name="has_supplier_account" invisible="1"/>
                        <group invisible="is_supplier_ticket">
                            <field name="balance" string="Total Ticket" widget="monetary"/>
                            <field name="total_remise" string="Remise" widget="monetary"/>
                            <field name="paid_amount" string="Payé" widget="monetary"/>
                            <field name="remaining_amount" string="Restant dû" widget="monetary"/>
                        </group>
                        <group string="Récapitulatif Fournisseur" invisible="not is_supplier_ticket">
                            <separator string="Total Espèces" colspan="2"/>
                            <field name="balance" string="Total Espèces" widget="monetary"/>
                            <field name="total_remise" string="Remise" widget="monetary"/>
                            <field name="paid_amount" string="Payé" widget="monetary"/>
                            <field name="remaining_amount" string="Restant Espèces" widget="monetary"/>
                            <separator string="Crédit Or" colspan="2"/>
                            <field name="ticket_gold_effect" string="Variation Or (g)"/>
                        </group>
                        <group string="Solde Fournisseur" invisible="not has_supplier_account">
                            <separator string="Compte Espèces" colspan="2"/>
                            <field name="partner_cash_balance_before" string="Solde Espèces Actuel" widget="monetary"/>
                            <field name="contrib_to_cash_balance" string="Variation Espèces" widget="monetary"/>
                            <field name="partner_cash_balance_after" string="Nouveau Solde Espèces" widget="monetary" class="o_stat_info"/>
                            <separator string="Compte Or" colspan="2"/>
                            <field name="partner_weight_balance_before" string="Solde Or Actuel (g)"/>
                            <field name="ticket_gold_effect" string="Variation Or (g)"/>
                            <field name="partner_weight_balance_after" string="Nouveau Solde Or (g)" class="o_stat_info"/>
                        </group>
                        <group string="Solde" invisible="has_supplier_account or is_supplier_ticket">
                            <field name="client_cash_balance" widget="monetary"/>
                            <button name="action_open_cash_balance_lines" type="object"
                                    string="Détails" class="btn-link oe_inline ml-2"/>
                        </group>
                    </group>
                    <separator string="Achat Or — Crédit Or" colspan="2"
                               invisible="not is_supplier_ticket"/>
                    <field name="gold_credit_line_ids" nolabel="1"
                           invisible="not is_supplier_ticket">
                        <tree>
                            <field name="metal_type_id" string="Métal"/>
                            <field name="weight" string="Poids (g)"/>
                            <field name="purity" string="Pureté (‰)"/>
                        </tree>
                    </field>
                    <group string="Payment">
                        <field name="payment_amount" widget="monetary"
                               placeholder="Enter amount to pay"
                               invisible="payment_status == 'paye'"/>
                        <field name="payment_type"
                               invisible="payment_status == 'paye'"/>
                        <field name="payment_method"
                               invisible="payment_status == 'paye'"/>
                        <button name="action_register_payment" type="object"
                                string="Register Payment" class="btn-primary"
                                colspan="2"
                                invisible="payment_status == 'paye'"/>
                    </group>
                    <separator string="Payment History" colspan="2"/>
                    <field name="cash_line_ids" nolabel="1">
                        <tree>
                            <field name="date"/>
                            <field name="type"/>
                            <field name="amount" widget="monetary"/>
                            <field name="user_id"/>
                            <field name="payment_method"/>
                            <field name="description"/>
                            <field name="reversed" invisible="1"/>
                            <button name="action_reverse_payment" type="object"
                                    string="Reverse" icon="fa-undo"
                                    confirm="Are you sure you want to reverse this payment?"
                                    invisible="reversed"/>
                        </tree>
                    </field>
                    <group>
                        <field name="notes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_jewelry_ticket_cash_balance_tree" model="ir.ui.view">
        <field name="name">jewelry.ticket.cash.balance.tree</field>
        <field name="model">jewelry.ticket</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" string="Ticket"/>
                <field name="date"/>
                <field name="payment_status" string="Payment"/>
                <field name="balance" string="Ticket Amount" widget="monetary"/>
                <field name="paid_amount" string="Paid" widget="monetary"/>
                <field name="contrib_to_cash_balance" string="Contribution" widget="monetary" sum="Total Contribution"/>
            </tree>
        </field>
    </record>

    <record id="view_jewelry_ticket_search" model="ir.ui.view">
        <field name="name">jewelry.ticket.search</field>
        <field name="model">jewelry.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="barcode"/>
                <field name="partner_id"/>
                <field name="cashier_id"/>
                <filter name="impaye" string="Impayé" domain="[('payment_status','=','impaye')]"/>
                <filter name="today" string="Today" domain="[('date','&gt;=',context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter name="type_vente" string="Vente" domain="[('ticket_line_ids.line_type','=','vente')]"/>
                <filter name="type_achat" string="Achat" domain="[('ticket_line_ids.line_type','=','achat')]"/>
                <filter name="type_achat_casse" string="Achat Casse" domain="[('ticket_line_ids.line_type','=','achat_casse')]"/>
                <filter name="type_fasonage" string="Fasonage" domain="[('ticket_line_ids.line_type','=','fasonage')]"/>
                <filter name="type_service" string="Service" domain="[('ticket_line_ids.line_type','=','service')]"/>
                <filter name="type_verse" string="Versé" domain="[('ticket_line_ids.line_type','=','verse')]"/>
                <filter name="type_solde" string="Solde" domain="[('ticket_line_ids.line_type','=','solde')]"/>
                <filter name="type_remise" string="Remise" domain="[('ticket_line_ids.line_type','=','remise')]"/>
                <filter name="type_personnel" string="Personnel" domain="[('ticket_line_ids.line_type','=','personnel')]"/>
                <filter name="type_fixe" string="Fixe" domain="[('ticket_line_ids.line_type','=','fixe')]"/>
            </search>
        </field>
    </record>

    <record id="action_jewelry_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">jewelry.ticket</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
