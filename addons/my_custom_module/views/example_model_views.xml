<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_my_custom_module_example_tree" model="ir.ui.view">
        <field name="name">my_custom_module.example.tree</field>
        <field name="model">my_custom_module.example</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="state"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_my_custom_module_example_form" model="ir.ui.view">
        <field name="name">my_custom_module.example.form</field>
        <field name="model">my_custom_module.example</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_my_custom_module_example_search" model="ir.ui.view">
        <field name="name">my_custom_module.example.search</field>
        <field name="model">my_custom_module.example</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="state"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_my_custom_module_example" model="ir.actions.act_window">
        <field name="name">My_custom_module Examples</field>
        <field name="res_model">my_custom_module.example</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first my_custom_module example!
            </p>
        </field>
    </record>

    <menuitem id="menu_my_custom_module_root" name="My_custom_module" sequence="100"/>
    <menuitem id="menu_my_custom_module_example" name="Examples" parent="menu_my_custom_module_root" action="action_my_custom_module_example"/>
</odoo>
