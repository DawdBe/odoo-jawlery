<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_bilan_global" model="ir.actions.report">
        <field name="name">Bilan Global</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">jewelry_accounting.bilan_global</field>
        <field name="report_file">jewelry_accounting.bilan_global</field>
        <field name="print_report_name">'Bilan Global - %s' % (time.strftime('%Y-%m-%d'))</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="bilan_global">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Bilan Global</h2>
                    <p>Generated: <span t-esc="time.strftime('%Y-%m-%d %H:%M')"/></p>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Journal Entry</th>
                                <th>Date</th>
                                <th>Operation</th>
                                <th>Weight</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="doc.line_ids" t-as="line">
                                <td><span t-esc="doc.name"/></td>
                                <td><span t-esc="doc.date"/></td>
                                <td><span t-esc="doc.jewelry_operation_type"/></td>
                                <td><span t-esc="line.weight"/></td>
                                <td><span t-esc="line.balance" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
