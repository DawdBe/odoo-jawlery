<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Transient Form — Bilan Courant ─────────────────────────────────── -->
    <record id="view_bilan_global_report_form" model="ir.ui.view">
        <field name="name">bilan.global.report.form</field>
        <field name="model">bilan.global.report</field>
        <field name="arch" type="xml">
            <form string="Bilan Patrimonial Global">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_print_bilan" string="Imprimer PDF"
                                type="object" class="btn-primary" icon="fa-print"/>
                        <button name="action_save_bilan" string="Sauvegarder dans l'historique"
                                type="object" class="btn-success" icon="fa-save"/>
                    </div>

                    <group string="Paramètres">
                        <group>
                            <field name="year" widget="integer"/>
                            <field name="mode" widget="radio"/>
                        </group>
                        <group>
                            <field name="date_cloture" readonly="1"/>
                            <field name="is_historical" invisible="1"/>
                        </group>
                    </group>

                    <group string="Avertissements" name="warnings"
                           invisible="not is_historical">
                        <div class="alert alert-warning" role="alert"
                             style="margin-bottom:0; padding: 8px 12px;">
                            <i class="fa fa-exclamation-triangle"/> Stock et trésorerie =
                            <b>valeur actuelle</b>, pas celle de <field name="year" class="oe_inline"/>.
                            Les créances, dettes, fournisseurs et associés sont filtrés à la date de clôture.
                        </div>
                    </group>

                    <group string="ACTIF">
                        <group>
                            <field name="stock_or_valorise" widget="monetary"/>
                            <button name="action_view_stock_or" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail stock Or"/>
                        </group>
                        <group>
                            <field name="stock_argent_valorise" widget="monetary"/>
                            <button name="action_view_stock_argent" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail stock Argent"/>
                        </group>
                        <group>
                            <field name="stock_autres_valorise" widget="monetary"/>
                            <button name="action_view_stock_autres" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail autres stocks"/>
                        </group>
                        <group>
                            <field name="tresorerie" widget="monetary"/>
                            <button name="action_view_tresorerie" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail caisses"/>
                        </group>
                        <group>
                            <field name="creances_clients" widget="monetary"/>
                            <button name="action_view_creances" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail créances"/>
                        </group>
                        <group>
                            <field name="total_actif" widget="monetary" class="font-weight-bold"/>
                        </group>
                    </group>

                    <group string="PASSIF">
                        <group>
                            <field name="capital_associes" widget="monetary"/>
                            <button name="action_view_associes" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail associés"/>
                        </group>
                        <group>
                            <field name="avances_associes" widget="monetary"/>
                            <button name="action_view_associes" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail associés"/>
                        </group>
                        <group>
                            <field name="dettes_fournisseurs" widget="monetary"/>
                            <button name="action_view_fournisseurs" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail fournisseurs"/>
                        </group>
                        <group>
                            <field name="dettes_clients" widget="monetary"/>
                            <button name="action_view_dettes_clients" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail clients créditeurs"/>
                        </group>
                        <group>
                            <field name="personnel" widget="monetary"/>
                            <button name="action_view_personnel" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail personnel"/>
                        </group>
                        <group>
                            <field name="investissements" widget="monetary"/>
                            <button name="action_view_investissements" type="object"
                                    icon="fa-external-link" class="btn-link" title="Détail investissements"/>
                        </group>
                        <group>
                            <field name="total_passif" widget="monetary" class="font-weight-bold"/>
                        </group>
                    </group>

                    <group string="Répartition par associé">
                        <field name="repartition_globale" nolabel="1" readonly="1"/>
                        <button name="action_view_associes" type="object"
                                string="Détail complet des associés"
                                icon="fa-users" class="btn-link"/>
                    </group>

                    <group string="Contrôle">
                        <group>
                            <field name="ecart_actif_passif" widget="monetary"/>
                        </group>
                        <group>
                            <field name="last_update"/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_recalculate" string="Recalculer"
                                type="object" class="btn-primary"/>
                        <button name="action_save_bilan" string="Sauvegarder"
                                type="object" class="btn-success"/>
                        <button special="cancel" string="Fermer" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── History Views ─────────────────────────────────────────────────── -->
    <record id="view_bilan_global_history_tree" model="ir.ui.view">
        <field name="name">bilan.global.history.tree</field>
        <field name="model">bilan.global.history</field>
        <field name="arch" type="xml">
            <tree string="Bilans patrimoniaux historiques" default_order="year desc, generated_on desc"
                   create="false" delete="false" editable="bottom">
                <field name="year"/>
                <field name="mode"/>
                <field name="date_cloture"/>
                <field name="generated_on"/>
                <field name="generated_by"/>
                <field name="total_actif" widget="monetary" sum="Total"/>
                <field name="total_passif" widget="monetary" sum="Total"/>
                <field name="ecart_actif_passif" widget="monetary"/>
                <field name="status" widget="badge" decoration-success="status == 'balanced'"
                       decoration-danger="status == 'not_balanced'"/>
                <button name="action_open_in_bilan" type="object"
                        string="Ouvrir le bilan" icon="fa-external-link" class="btn-link"/>
            </tree>
        </field>
    </record>

    <record id="view_bilan_global_history_form" model="ir.ui.view">
        <field name="name">bilan.global.history.form</field>
        <field name="model">bilan.global.history</field>
        <field name="arch" type="xml">
            <form string="Bilan Patrimonial Global — Historique">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_in_bilan" string="Ouvrir dans le Bilan"
                                type="object" class="btn-primary" icon="fa-external-link"/>
                        <button name="action_print_bilan" string="Imprimer PDF"
                                type="object" class="btn-secondary" icon="fa-print"/>
                    </div>

                    <group string="Paramètres">
                        <group>
                            <field name="year"/>
                            <field name="mode"/>
                        </group>
                        <group>
                            <field name="date_cloture"/>
                            <field name="generated_on"/>
                            <field name="generated_by"/>
                        </group>
                    </group>

                    <group string="ACTIF" col="4">
                        <field name="stock_or_valorise" widget="monetary"/>
                        <button name="action_view_stock_or" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail stock Or"/>
                        <field name="stock_argent_valorise" widget="monetary"/>
                        <button name="action_view_stock_argent" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail stock Argent"/>
                        <field name="stock_autres_valorise" widget="monetary"/>
                        <button name="action_view_stock_autres" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail autres stocks"/>
                        <field name="tresorerie" widget="monetary"/>
                        <button name="action_view_tresorerie" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail caisses"/>
                        <field name="creances_clients" widget="monetary"/>
                        <button name="action_view_creances" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail créances"/>
                        <field name="total_actif" widget="monetary" class="font-weight-bold"/>
                    </group>

                    <group string="PASSIF" col="4">
                        <field name="capital_associes" widget="monetary"/>
                        <button name="action_view_associes" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail associés"/>
                        <field name="avances_associes" widget="monetary"/>
                        <button name="action_view_associes" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail associés"/>
                        <field name="dettes_fournisseurs" widget="monetary"/>
                        <button name="action_view_fournisseurs" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail fournisseurs"/>
                        <field name="dettes_clients" widget="monetary"/>
                        <button name="action_view_dettes_clients" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail clients créditeurs"/>
                        <field name="personnel" widget="monetary"/>
                        <button name="action_view_personnel" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail personnel"/>
                        <field name="investissements" widget="monetary"/>
                        <button name="action_view_investissements" type="object"
                                icon="fa-external-link" class="btn-link" title="Détail investissements"/>
                        <field name="total_passif" widget="monetary" class="font-weight-bold"/>
                    </group>

                    <group string="Répartition par associé">
                        <field name="repartition_globale" nolabel="1" readonly="1"/>
                    </group>

                    <group string="Contrôle" col="4">
                        <field name="ecart_actif_passif" widget="monetary"/>
                        <field name="status" widget="badge"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bilan_global_history_search" model="ir.ui.view">
        <field name="name">bilan.global.history.search</field>
        <field name="model">bilan.global.history</field>
        <field name="arch" type="xml">
            <search string="Rechercher bilans">
                <field name="year"/>
                <field name="mode"/>
                <field name="generated_by"/>
                <field name="status"/>
                <filter name="year_current" string="Année en cours"
                        domain="[('year', '=', datetime.now().year)]"/>
                <filter name="balanced" string="Équilibrés"
                        domain="[('status', '=', 'balanced')]"/>
                <filter name="not_balanced" string="Non équilibrés"
                        domain="[('status', '=', 'not_balanced')]"/>
                <separator/>
                <group expand="0" string="Group by">
                    <filter name="group_year" string="Année"
                            context="{'group_by': 'year'}"/>
                    <filter name="group_status" string="Statut"
                            context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
