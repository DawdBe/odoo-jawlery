<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_jewelry_accounting" name="Accounting"
               parent="jewelry_core.menu_jewelry_root" sequence="30"/>

    <!-- Bilan courant (TransientModel) -->
    <record id="action_jewelry_bilan_global" model="ir.actions.act_window">
        <field name="name">Bilan Patrimonial</field>
        <field name="res_model">bilan.global.report</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <menuitem id="menu_jewelry_bilan_global" name="Bilan Patrimonial"
              parent="menu_jewelry_accounting" action="action_jewelry_bilan_global" sequence="10"/>

    <!-- Bilan historique (model persistant) -->
    <record id="action_jewelry_bilan_global_history" model="ir.actions.act_window">
        <field name="name">Bilans patrimoniaux historiques</field>
        <field name="res_model">bilan.global.history</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p>Cliquez sur <b>Ouvrir le bilan</b> pour ouvrir le Bilan Patrimonial avec les paramètres de l'enregistrement historique.</p>
        </field>
    </record>

    <menuitem id="menu_jewelry_bilan_global_history" name="Bilans historiques"
              parent="menu_jewelry_accounting" action="action_jewelry_bilan_global_history" sequence="15"/>

    <!-- Journal des écritures comptables -->
    <record id="action_jewelry_account_move" model="ir.actions.act_window">
        <field name="name">Journal des écritures</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('jewelry_operation_type', '!=', False)]</field>
        <field name="context">{'search_default_group_by': 'jewelry_operation_type'}</field>
    </record>

    <menuitem id="menu_jewelry_account_move" name="Journal des écritures"
              parent="menu_jewelry_accounting" action="action_jewelry_account_move" sequence="20"/>
</odoo>
