@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

' ============================================
' PACKAGE: jewelry_core (Socle)
' ============================================
package "jewelry_core" as CORE {

  class "metal.type" as MetalType {
    - name : Char (required)
    - code : Char (AU, AG, PT)
    - purity_percentage : Float
    - karat_value : Float
    - active : Boolean
    - category : Selection (or/argent/casse/plaque/perle/devise)
    -- Méthodes --
    + get_current_rate(rate_type) : Float
  }

  class "gold.rate.history" as GoldRate {
    - metal_type_id : Many2one(metal.type)
    - bursa_rate : Monetary (cours bourse, référence)
    - market_rate : Monetary (cours marché réel, utilisé pour transactions)
    - market_spread : Monetary (écart bourse→marché, configurable)
    - is_active : Boolean
    - currency_id : Many2one(res.currency)
    - effective_date : Date
    - created_by : Many2one(res.users)
    - notes : Text
  }

  class "product.template" as ProductTemplate {
    - metal_type_id : Many2one(metal.type)
    - jewelry_category : Selection (fini/brut/pierre/fourniture)
    - gross_weight : Float (g)
    - stone_weight : Float (g)
    - net_weight : Float (g) [compute]
    - barcode : Char (encode attributs produit)
    - style : Selection (massif/massif_lux/bataille/massif_controlé/mesaise/or_750)
  }

  class "product.product" as ProductProduct {
    - serial_number : Char
    - certificate_number : Char
    - weight : Float (g)
    - location_id : Many2one(stock.location)
  }

  class "product.category" as ProductCategory {
    - has_weight : Boolean (True = vendu au poids, False = prix fixe)
    - is_jewelry : Boolean
  }

  class "stock.quant" as StockQuant {
    - product_id : Many2one(product.product)
    - location_id : Many2one(stock.location)
    - quantity : Float
    - weight_total : Float (g)
    - metal_type_id : Many2one(metal.type)
    - estimated_value : Monetary [compute]
  }

  class "stock.move" as StockMove {
    - product_id : Many2one(product.product)
    - location_id : Many2one(stock.location)
    - location_dest_id : Many2one(stock.location)
    - product_uom_qty : Float
    - weight_total : Float (g)
    - metal_type_id : Many2one(metal.type)
    - move_type : Selection (achat/vente/transfert/fasonage/fonte)
  }

  class "stock.inventory.weight" as WeightInventory {
    - name : Char
    - date : Date
    - state : Selection (draft/in_progress/done)
    - metal_type_id : Many2one(metal.type)
    - expected_weight : Float (poids attendu selon stock)
    - actual_weight : Float (poids pesé physiquement)
    - difference_weight : Float (g) [compute]
    -- Méthodes --
    + reconcile_weights() : void
  }

  class "stock.inventory.weight.line" as WeightInventoryLine {
    - inventory_id : Many2one(stock.inventory.weight)
    - product_id : Many2one(product.product)
    - weight_before : Float
    - weight_after : Float
    - weight_difference : Float (g) [compute]
    - notes : Text
  }

  class "res.partner" as ResPartner {
    - client_code : Char
    - partner_type : Selection (client/FRS/atelier/associé)
    - is_supplier : Boolean
    - is_atelier : Boolean
    - is_associated : Boolean
    - phone : Char
    - notes : Text
  }

  MetalType "1" -- "0..*" GoldRate : rates
  MetalType "1" -- "0..*" ProductTemplate : classifies
  ProductTemplate "1" -- "0..*" ProductProduct : has_variants
  ProductCategory "1" -- "0..*" ProductTemplate : categorized_by
  ProductProduct --> StockQuant : quantity_in
  ProductProduct --> StockMove : moved_by
  WeightInventory "1" -- "0..*" WeightInventoryLine : lines
  WeightInventoryLine --> ProductProduct : counts
  WeightInventory --> MetalType : tracks
}

' ============================================
' PACKAGE: jewelry_transactions (Cœur Métier)
' ============================================
package "jewelry_transactions" as TRANS {

  class "jewelry.ticket" as JewelryTicket {
    - name : Char (bon #)
    - partner_id : Many2one(res.partner)
    - date : Datetime
    - cashier_id : Many2one(res.users)
    - seller_id : Many2one(res.users)
    - payment_status : Selection (impaye/partiel/paye)
    - product_status : Selection (en_stock/en_fasonage/termine/donne_au_client)
    - total_cash_in : Monetary [compute store]
    - total_cash_out : Monetary [compute store]
    - balance : Monetary [compute store]
    - total_remise : Monetary [compute store] (somme des remises)
    - notes : Text
    -- Méthodes --
    + compute_balance() : Monetary
    + register_payment(amount) : void
  }

  class "jewelry.ticket.line" as TicketLine {
    - ticket_id : Many2one(jewelry.ticket)
    - line_type : Selection (vente/achat_casse/achat/service/fasonage/versé/solde/remise)
    - product_id : Many2one(product.product)
    - weight : Float (g)
    - metal_type_id : Many2one(metal.type)
    - description : Char
    - price_unit : Monetary (prix final après remise)
    - price_subtotal : Monetary
    - remise_type : Selection (none/percentage/fixed)
    - remise_value : Float (% ou montant selon type)
    - remise_amount : Monetary [compute] (montant de la remise)
    - notes : Text
  }

  class "purchase.order" as PurchaseOrder {
    - name : Char
    - partner_id : Many2one(res.partner)
    - date_order : Datetime
    - is_consignment : Boolean
    - gold_weight_in : Float
    - gold_weight_out : Float
    - gold_metal_type : Many2one(metal.type)
    - partner_type : Selection (fournisseur/atelier)
    -- Méthodes --
    + settle_gold_trade() : void
  }

  class "purchase.order.line" as PurchaseOrderLine {
    - product_id : Many2one(product.product)
    - weight : Float (g)
    - metal_type_id : Many2one(metal.type)
    - is_raw_gold : Boolean
    - unit_price_per_gram : Monetary
    - line_type : Selection (achat/transfert/consignation)
  }

  class "supplier.account" as SupplierAccount {
    - partner_id : Many2one(res.partner)
    - partner_type : Selection (fournisseur/atelier)
    - weight_balance : Float (g) (poids dû) [compute store]
    - cash_balance : Monetary (argent dû) [compute store]
    - last_rate_used : Monetary
    - last_transaction_date : Datetime
    -- Méthodes --
    + compute_weight_value(current_rate) : Monetary
    + record_sale(weight, cash) : void
    + record_return(weight) : void
    + record_cash_payment(amount) : void
  }

  class "casse.melting.line" as CasseMeltingLine {
    - melting_id : Many2one(casse.melting)
    - ticket_line_id : Many2one(jewelry.ticket.line)
    - weight : Float (g)
    - cost : Monetary
  }

  class "casse.melting" as CasseMelting {
    - name : Char
    - date : Date
    - metal_type_result : Many2one(metal.type) (résultat après fonte)
    - karat_result : Float (pureté mesurée après fonte)
    - weight_before : Float (g) (poids total des déchets fondus)
    - weight_after : Float (g) (poids or raffiné obtenu)
    - wastage_weight : Float (g) [compute store]
    - total_cost : Monetary (total payé pour le lot de casse)
    - refined_value : Monetary [compute store] (weight_after × market_rate)
    - profit : Monetary [compute store] (refined_value - total_cost)
    - state : Selection (draft/done)
    - notes : Text
    -- Méthodes --
    + compute_profit() : Monetary
  }

  class "service.order" as ServiceOrder {
    - name : Char
    - partner_id : Many2one(res.partner)
    - atelier_id : Many2one(res.partner)
    - ticket_id : Many2one(jewelry.ticket)
    - service_type : Selection (fasonage/reparation/dorure/argenture/gravure/goupelle)
    - style : Selection (massif/massif_lux/bataille/massif_controlé/mesaise/or_750)
    - raw_gold_weight : Float (g)
    - raw_gold_metal : Many2one(metal.type)
    - finished_weight : Float (g)
    - wastage_weight : Float (g) [compute]
    - wastage_percentage : Float
    - status : Selection (received/in_progress/ready/delivered)
    - payment_status : Selection (impaye/partiel/paye)
    - price_from_table : Monetary [compute]
    - min_profit_percentage : Float (% marge souhaitée)
    - received_date : Datetime
    - estimated_ready_date : Date
    - notes : Text
    -- Méthodes --
    + compute_wastage() : Float
    + lookup_price_from_table() : Monetary
    + validate_selling_price(proposed_price) : Boolean
  }

  class "atelier.price.table" as AtelierPriceTable {
    - atelier_id : Many2one(res.partner)
    - style : Selection (massif/massif_lux/bataille/massif_controlé/mesaise/or_750)
    - metal_type_id : Many2one(metal.type)
    - cost_per_gram : Monetary
    - notes : Text
  }

  class "daily.cash.register" as DailyCash {
    - name : Char
    - opening_balance : Monetary
    - closing_balance : Monetary
    - expected_balance : Monetary [compute store]
    - difference : Monetary [compute store]
    - cashier_id : Many2one(res.users)
    - date : Date
    - state : Selection (open/closed/verified)
    - breakdown_2000/1000/500/200/100/50/20/10 : Integer
    -- Méthodes --
    + compute_difference() : Monetary
    + close_register() : void
  }

  class "cash.register.line" as CashLine {
    - register_id : Many2one(daily.cash.register)
    - ticket_id : Many2one(jewelry.ticket)
    - amount : Monetary
    - type : Selection (entrée/sortie)
    - is_travel_cash : Boolean (caisse de voyage)
    - journal_id : Many2one(account.journal)
    - partner_id : Many2one(res.partner)
    - weight : Float (g)
    - description : Char
    - reference : Char
  }

  class "associate.account" as AssociateAccount {
    - partner_id : Many2one(res.partner)
    - capital_balance : Monetary (capital actuel) [compute store]
    - advance_balance : Monetary (avances sur profits) [compute store]
    - last_transaction_date : Datetime
    -- Méthodes --
    + compute_balances() : void
    + record_transaction(type, amount, notes) : void
  }

  class "associate.transaction" as AssociateTransaction {
    - partner_id : Many2one(res.partner)
    - transaction_type : Selection (capital_deposit/capital_withdrawal/advance_profit/profit_distribution/profit_effort/zakat)
    - amount : Monetary
    - date : Datetime
    - fiscal_year : Char
    - ticket_id : Many2one(jewelry.ticket)
    - notes : Text
  }

  class "product.promotion" as ProductPromotion {
    - name : Char
    - active : Boolean
    - promotion_type : Selection (percentage/fixed_price)
    - value : Float (% ou prix fixe)
    - applicable_on : Selection (all/category/style/metal_type/product)
    - metal_type_id : Many2one(metal.type)
    - product_category_id : Many2one(product.category)
    - style : Selection (massif/massif_lux/bataille/massif_controlé/mesaise/or_750)
    - product_id : Many2one(product.product)
    - date_start : Date
    - date_end : Date
    - notes : Text
    -- Méthodes --
    + get_applicable_price(product, metal_type, style) : Monetary
  }

  JewelryTicket "1" -- "0..*" TicketLine : contains
  ResPartner "1" -- "0..*" JewelryTicket : participates
  PurchaseOrder "1" -- "0..*" PurchaseOrderLine : contains
  SupplierAccount "1" -- "0..*" PurchaseOrder : tracks
  ResPartner "1" -- "0..*" PurchaseOrder : orders
  ResPartner "1" -- "1" SupplierAccount : has_account
  ProductPromotion --> ProductTemplate : applies_to
  ProductPromotion --> ProductCategory : on_category
  ProductPromotion --> MetalType : on_metal
  ResPartner "1" -- "1" AssociateAccount : has_account
  AssociateAccount "1" -- "0..*" AssociateTransaction : contains
  AssociateTransaction --> ResPartner : partner
  AssociateTransaction --> JewelryTicket : linked_ticket
  DailyCash "1" -- "0..*" CashLine : contains
  CashLine --> JewelryTicket : references
  ServiceOrder --> JewelryTicket : linked_to
  ServiceOrder --> AtelierPriceTable : priced_by
  ResPartner "1" -- "0..*" AtelierPriceTable : provides
  CashLine --> SupplierAccount : impacts_balance
  CasseMelting "1" -- "0..*" CasseMeltingLine : contains
  CasseMeltingLine --> TicketLine : sourced_from
  CasseMelting --> MetalType : produces
  TRANS --> CORE : uses metal.type,\nproduct, stock
}

' ============================================
' PACKAGE: jewelry_accounting (Rapports)
' ============================================
package "jewelry_accounting" as ACCOUNTING {
  class "account.move" as AccountMove {
    - name : Char
    - date : Date
    - jewelry_operation_type : Selection (vente/achat/fasonage/service/frais/associé/personnel/invest/transfert/versé/solde/remise)
    - weight_total : Float
    - partner_id : Many2one(res.partner)
    -- Méthodes --
    + generate_legal_report() : void
  }

  class "account.move.line" as AccountMoveLine {
    - account_id : Many2one(account.account)
    - partner_id : Many2one(res.partner)
    - weight : Float
    - metal_type_id : Many2one(metal.type)
    - quantity : Float
    - price_unit : Monetary
    - balance : Monetary
  }
}

' ============================================
' PACKAGE: jewelry_dashboard (UI)
' ============================================
package "jewelry_dashboard" as DASHBOARD {
  class "dashboard.360" as Dashboard360 <<TransientModel>> {
    - total_cash : Monetary [compute]
    - weight_by_metal_type : Text [compute] (poids par type de métal)
    - today_sales : Monetary [compute]
    - today_profit : Monetary [compute]
    - today_remise : Monetary [compute] (total remises du jour)
    - pending_payments : Monetary [compute]
    - pending_fasonages : Integer [compute]
    - gold_rate_bursa/market : Monetary [compute]
    - silver_rate : Monetary [compute]
    - last_update : Datetime [compute]
  }
}

' ============================================
' RELATIONS INTER-PACKAGES
' ============================================
JewelryTicket --> StockMove : generates_moves
JewelryTicket --> AccountMove : generates_invoice
PurchaseOrder --> StockMove : generates
ServiceOrder --> StockMove : from_raw_to_finished
DailyCash --> ResPartner : cashier
SupplierAccount --> ResPartner : fournisseur/atelier
AccountMove --> ResPartner : partner

legend bottom
  **4 modules custom:**
  jewelry_core = Socle (métaux, cours, produits, inventaire)
  jewelry_transactions = Métier (ticket, achats, services, caisse, fonte casse)
  jewelry_accounting = Rapports (écritures, bilans)
  jewelry_dashboard = UI (vue 360°)
  ---
  Caisse voyage = champ is_travel_cash sur cash.register.line
  Casse = pas de sous-types — un seul type "Casse" dans metal.type
  Prix achat casse = saisi manuellement (évaluation visuelle)
  Karat depuis metal.type — pas de champ karat redondant
endlegend

@enduml
